<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.Controller">

    <center>
        <StackPane fx:id="leftPane" style="-fx-border-color: #ccc;">
        </StackPane>
    </center>

    <right>
        <VBox alignment="CENTER" prefWidth="320.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #eee;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="LOGIN" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333;" />

                <VBox spacing="5.0">
                    <children>
                        <Label text="Username:" />
                        <TextField fx:id="txtUsername" promptText="Enter username" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Password:" />
                        <PasswordField fx:id="txtPassword" promptText="Enter password" />
                    </children>
                </VBox>

                <HBox spacing="20.0" alignment="CENTER">
                    <children>
                        <RadioButton fx:id="rbBidder" text="Người mua (Bidder)" selected="true">
                            <toggleGroup>
                                <ToggleGroup fx:id="roleGroup" />
                            </toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="rbSeller" text="Người bán (Seller)" toggleGroup="$roleGroup" />
                    </children>
                    <padding>
                        <Insets top="10.0" bottom="10.0" />
                    </padding>
                </HBox>

                <HBox spacing="10.0" alignment="CENTER">
                    <children>
                        <Button fx:id="btnLogin" onAction="#handleLogin" text="Login" prefWidth="100.0"
                                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;" />
                        <Button fx:id="btnRegister" onAction="#handleRegister" text="Register" prefWidth="100.0"
                                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;"/>
                    </children>
                    <padding>
                        <Insets top="10.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </right>

</BorderPane>