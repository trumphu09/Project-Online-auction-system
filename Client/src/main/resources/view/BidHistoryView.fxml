<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controllers.BidHistoryController">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <Label text="Auction ID:" />
            <TextField fx:id="txtAuctionId" promptText="Enter auction ID" />
            <Button fx:id="btnLoadHistory" onAction="#loadBidHistory" text="Load History" />
            <Button fx:id="btnSetupAutoBid" onAction="#setupAutoBid" text="Setup Auto-Bid" />
         </children>
      </HBox>

      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <Label text="Max Bid:" />
            <TextField fx:id="txtMaxBid" promptText="Enter max bid amount" />
            <Label text="Increment:" />
            <TextField fx:id="txtIncrement" promptText="Enter increment amount" />
         </children>
      </HBox>

      <LineChart fx:id="bidHistoryChart" title="Bid History Over Time" VBox.vgrow="ALWAYS">
         <xAxis>
            <CategoryAxis fx:id="timeAxis" label="Time" />
         </xAxis>
         <yAxis>
            <NumberAxis fx:id="priceAxis" label="Bid Amount ($)" />
         </yAxis>
      </LineChart>

      <HBox spacing="10.0">
         <children>
            <Label fx:id="lblCurrentPrice" text="Current Price: $0.00" />
            <Label fx:id="lblTotalBids" text="Total Bids: 0" />
            <Label fx:id="lblTimeRemaining" text="Time Remaining: --:--" />
         </children>
      </HBox>

      <HBox spacing="10.0">
         <children>
            <TextField fx:id="txtBidAmount" promptText="Enter your bid" />
            <Button fx:id="btnPlaceBid" onAction="#placeBid" text="Place Bid" />
            <Button fx:id="btnBack" onAction="#goBack" text="Back" />
         </children>
      </HBox>
   </children>
</VBox>