<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controllers.AdminController">

    <left>
        <VBox spacing="15.0" style="-fx-background-color: #2c3e50; -fx-pref-width: 200;">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>
            <children>
                <Label text="ADMIN" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" alignment="CENTER"/>
                <Separator opacity="0.3"/>
                <Button fx:id="btnManageUsers" onAction="#showUserManagement" text="Quản lý Người dùng" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
                <Button fx:id="btnManageItems" onAction="#showItemManagement" text="Quản lý Sản phẩm" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
              
                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#handleLogout" text="Đăng xuất" maxWidth="Infinity" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;"/>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="10.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label fx:id="lblTitle" text="Danh sách người dùng" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="txtSearch" promptText="Tìm kiếm..." prefWidth="200.0"/>
                    </children>
                </HBox>

                <TableView fx:id="tableData" VBox.vgrow="ALWAYS">
                </TableView>

                <HBox spacing="15.0" alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="btnLock" onAction="#handleLockUnlock" text="Khóa Tài Khoản" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-cursor: hand;"/>
                        <Button fx:id="btnDelete" onAction="#handleDelete" text="Xóa Sản Phẩm" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-cursor: hand;"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>