<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.RegisterController"
           prefHeight="500.0" prefWidth="800.0"
           style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 100%);">

    <children>
        <VBox alignment="CENTER" maxHeight="400.0" maxWidth="350.0" spacing="10.0"
              style="-fx-background-color: white;
                     -fx-background-radius: 15px;">

            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <children>
                <Label text="CREATE ACCOUNT" textFill="#2d6cdf" style="-fx-font-size: 18px; -fx-font-weight: bold;">
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <TextField fx:id="regUsername" promptText="Username"
                           style="-fx-background-color: white;
                                  -fx-border-color: #ddd;
                                  -fx-border-radius: 8px;
                                  -fx-prompt-text-fill: #aaa;
                                  -fx-padding: 6px;"/>

                <PasswordField fx:id="regPassword" promptText="Password"
                               style="-fx-background-color: white;
                                      -fx-border-color: #ddd;
                                      -fx-border-radius: 8px;
                                      -fx-prompt-text-fill: #aaa;
                                      -fx-padding: 6px;"/>

                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button onAction="#handleSignUpSeller" text="Seller Sign Up"
                                style="-fx-background-color: #2d6cdf;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 20px;
                       -fx-padding: 6px 15px;
                       -fx-cursor: hand;"/>

                        <Button onAction="#handleSignUpBidder" text="Bidder Sign Up"
                                style="-fx-background-color: #2d6cdf;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 20px;
                       -fx-padding: 6px 15px;
                       -fx-cursor: hand;"/>
                    </children>
                </HBox>
                <Button onAction="#handleBackToLogin" text="Return"
                        style="-fx-background-color: white;
                               -fx-text-fill: black;
                               -fx-font-weight: bold;
                               -fx-background-radius: 20px;
                               -fx-padding: 6px 30px;
                               -fx-cursor: hand;"/>

            </children>
        </VBox>
    </children>
</StackPane>